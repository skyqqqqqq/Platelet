":"Nn2Ro2BGnCwY"}},{"cell_type":"code","source":["def run_inference():\n","    # Check if input directory exists\n","    if not os.path.exists(INPUT_DIR):\n","        print(f\"Error: Input directory {INPUT_DIR} does not exist.\")\n","        return\n","\n","    # Support multiple formats\n","    files = [f for f in os.listdir(INPUT_DIR) if f.endswith('.tiff')]\n","    print(f\"找到 {len(files)} 张图片，准备处理...\")\n","\n","    for filename in files:\n","        img_path = os.path.join(INPUT_DIR, filename)\n","\n","        # 1. 读取图片\n","        img = cv2.imread(img_path)\n","        if img is None: continue\n","        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n","\n","        # 2. 推理预测\n","        if 'model' not in globals():\n","            print(\"Error: 'model' is not defined. Please run the cell that loads the model first.\")\n","            return\n","\n","        masks, flows, styles = model.eval(\n","            img,\n","            diameter=90,\n","            channels=[0, 0],\n","            flow_threshold=0.7,\n","            cellprob_threshold=-1.0\n","        )\n","\n","        # 3. 保存可视化对比图 (使用内置函数)\n","        # show_segmentation 会自动生成包含 原图+轮廓、CellProb、Flows 的组合图\n","        fig = plt.figure(figsize=(12, 5))\n","        plot.show_segmentation(fig, img, masks, flows[0], channels=[0, 0])\n","        plt.tight_layout()\n","\n","        save_name = os.path.splitext(filename)[0]\n","        save_path = os.path.join(OUTPUT_DIR, f\"{save_name}_combo.png\")\n","        plt.savefig(save_path, dpi=150)\n","        plt.close(fig)\n","\n","        # 4. 保存纯 Mask 数据\n","        mask_path = os.path.join(OUTPUT_DIR, f\"mask_{filename}\")\n","        cv2.imwrite(mask_path, masks.astype(np.uint16))\n","\n","    print(f\"所有图片处理完成！结果保存在: {OUTPUT_DIR}\")\n","\n","run_inference()"],"metadata":{"id":"as_9kdh_jp0j"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["网格参数测试，对整个sample文件夹"],"metadata":{"id":"ZH7b5IEHdsNC"}},{"cell_type":"code","source":["import os\n","import cv2\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from cellpose import models, utils\n","\n","# --- 路径配置 ---\n","INPUT_DIR = '/content/drive/MyDrive/sample_20/intensity'\n","OUTPUT_DIR = '/content/drive/MyDrive/sample_20/intersity_results'\n","os.makedirs(OUTPUT_DIR, exist_ok=True) # Added: Create the output directory if it doesn't exist\n","\n","# --- 设置搜索范围 ---\n","# flow_threshold: 越高切割力越强\n","# cellprob_threshold: 越高越能剔除边缘粘连和背景噪声\n","flow_options = [0.1,0.2,0.3, 0.4, 0.6,]\n","prob_options = [-2.0, -1.0, 0.0, 2.0]\n","\n","# --- 获取所有测试图片 ---\n","image_files = [f for f in os.listdir(INPUT_DIR) if f.endswith(('.tiff'))]\n","\n","print(f\"找到 {len(image_files)} 张图片，准备进行网格测试...\")\n","\n","for test_img_name in image_files:\n","    img_path = os.path.join(INPUT_DIR, test_img_name)\n","    img = cv2.imread(img_path)\n","    if img is None:\n","        print(f\"警告：无法读取图片 {test_img_name}，跳过。\")\n","        continue\n","    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n","\n","    # --- 绘图准备 ---\n","    fig, axes = plt.subplots(len(flow_options), len(prob_options), figsize=(18, 18))\n","    plt.subplots_adjust(wspace=0.1, hspace=0.3)\n","    fig.suptitle(f'Parameter Grid Search: {test_img_name}\\n(Transformer Model)', fontsize=20)\n","\n","    print(f\"正在对图片 {test_img_name} 进行网格测试，请稍候...\")\n","\n","    for i, f_thresh in enumerate(flow_options):\n","        for j, p_thresh in enumerate(prob_options):\n","            # 推理\n","            masks, flows, styles = model.eval(\n","                img,\n","                diameter=90,\n","                channels=[0, 0],\n","                flow_threshold=f_thresh,\n","                cellprob_threshold=p_thresh\n","            )\n","\n","            # 制作叠加图\n","            outlines = utils.masks_to_outlines(masks)\n","            overlay = img.copy()\n","            overlay[outlines] = [255, 0, 0] # 红色边缘\n","\n","            # 绘图\n","            ax = axes[i, j]\n","            ax.imshow(overlay)\n","            ax.set_title(f\"Flow: {f_thresh} | Prob: {p_thresh}\\nCells Count: {len(np.unique(masks))-1}\", fontsize=12)\n","            ax.axis('off')\n","\n","    plt.show()\n","\n","    # 保存对比图到 Drive\n","    output_filename = f\"parameter_grid_search_{os.path.splitext(test_img_name)[0]}.png\"\n","    plt.savefig(os.path.join(OUTPUT_DIR, output_filename), bbox_inches='tight')\n","    print(f\"对比图已保存至: {os.path.join(OUTPUT_DIR, output_filename)}\")\n","    plt.close(fig) # 关闭当前图，释放内存\n","\n","print(f\"所有图片网格测试完成！结果保存在: {OUTPUT_DIR}\")"],"metadata":{"id":"_ATTeh6ddr7e"},"execution_count":null,"outputs":[]}]}