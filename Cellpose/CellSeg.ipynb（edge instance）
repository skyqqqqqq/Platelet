镜设置调整）\n","PIXEL_TO_MICRON = 0.08  # µm/pixel\n","\n","# 特征计算阈值\n","AREA_THRESHOLD_UM2 = 40.0  # 面积阈值 (µm²)\n","area_threshold_px = AREA_THRESHOLD_UM2 / (PIXEL_TO_MICRON ** 2)  # 转换为像素阈值\n","SOLIDITY_THRESHOLD = 0.85  # 紧实度阈值\n","ASPECT_RATIO_THRESHOLD = 1.8  # 伸长比阈值\n","\n","# Cluster Count Estimation 参数\n","CELL_DIAMETER = 90  # 细胞直径 (像素)，基于模型diameter参数\n","NEIGHBOR_DISTANCE_THRESHOLD = CELL_DIAMETER  # 邻居距离阈值 (像素)\n","NEIGHBOR_COUNT_THRESHOLD = 2  # 邻居数量阈值，如果邻居数 > 此值，则认为是聚集体\n","\n","# 物理常数 (用于干质量计算)\n","WAVELENGTH = 1030e-9  # 中心波长 (米)\n","ALPHA = 0.2          # 折射增量 (mL/g)\n","\n","\n","# 创建顶级输出目录 (只创建一次)\n","os.makedirs(OUTPUT_DIR, exist_ok=True)\n","# 其他子目录将在处理过程中动态创建\n","\n","# =============================================================================\n","# 设备和模型初始化\n","# =============================================================================\n","device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n","print(f\"使用设备: {device}\")\n","\n","# 加载CellSeg-Transformer模型\n","model = models.CellposeModel(gpu=torch.cuda.is_available())"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["使用设备: cpu\n"]}]},{"cell_type":"code","source":["import os\n","# Cellpose 默认的模型存储路径\n","cp_model_path = os.path.expanduser('~/.cellpose/models')\n","\n","if os.path.exists(cp_model_path):\n","    print(f\"权重存储目录: {cp_model_path}\")\n","    print(\"已下载的模型权重文件:\")\n","    for f in os.listdir(cp_model_path):\n","        print(f\" - {f}\")\n","else:\n","    print(\"目录尚未创建，模型可能还在内存中或尚未成功下载。\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"9KU1JrtVX1Gz","executionInfo":{"status":"ok","timestamp":1772973007318,"user_tz":-480,"elapsed":4,"user":{"displayName":"yihan wang","userId":"01367579912082978010"}},"outputId":"ed505e65-704d-465f-b451-954036cd979e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["权重存储目录: /root/.cellpose/models\n","已下载的模型权重文件:\n"," - cpsam\n"]}]},{"cell_type":"code","source":["def fractal_dimension_boxcount(bin_img, box_sizes=None, min_box=2, max_box=None, return_counts=False):\n","    \"\"\"\n","    使用盒计数法计算二维二值图像的分形维数。\n","\n","    参数:\n","        bin_img: 二值图像 (numpy.ndarray)\n","        box_sizes: 自定义盒子尺寸列表 (list, optional)\n","        min_box: 最小盒子尺寸 (int)\n","        max_box: 最大盒子尺寸 (int, optional)\n","        return_counts: 是否返回计数数据 (bool)\n","\n","    返回:\n","        分形维数 (float) 或 (分形维数, 尺寸列表, 计数列表)\n","    \"\"\"\n","    # 输入校验和二值化\n","    if bin_img is None:\n","        return (0.0, [], []) if return_counts else 0.0\n","    Z = np.asarray(bin_img)\n","    if Z.ndim != 2:\n","        raise ValueError(\"输入必须为二维数组\")\n","    binZ = (Z != 0).astype(np.uint8)\n","    if not np.any(binZ):\n","        return (0.0, [], []) if return_counts else 0.0\n","\n","    h, w = binZ.shape\n","    min_dim = min(h, w)\n","\n","    # 确定盒子尺寸序列\n","    if box_sizes is None:\n","        if max_box is None:\n","            max_box = max(1, min_dim // 2)\n","        sizes = [2 ** k for k in range(int(np.log2(min_box)), int(np.log2(max_box)) + 1)]\n","        sizes = [s for s in sizes if min_box <= s <= max_box]\n","        if len(sizes) < 2:\n","            sizes = np.unique(np.linspace(min_box, max_box, num=5, dtype=int)).tolist()\n","    else:\n","        sizes = sorted([int(s) for s in np.unique(np.array(box_sizes, dtype=int)) if 1 <= s <= min_dim])\n","\n","    if len(sizes) == 0:\n","        return (0.0, [], []) if return_counts else 0.0\n","\n","    counts = []\n","    # 对每个尺寸进行盒计数\n","    for s in sizes:\n","        # 填充图像以整除盒子尺寸\n","        pad_h = (s - (h % s)) % s\n","        pad_w = (s - (w % s)) % s\n","        if pad_h > 0 or pad_w > 0:\n","            padded = np.pad(binZ, ((0, pad_h), (0, pad_w)), mode='constant', constant_values=0)\n","        else:\n","            padded = binZ\n","\n","        new_h, new_w = padded.shape\n","        nbh, nbw = new_h // s, new_w // s\n","\n","        # 矢量化计算块和\n","        try:\n","            reshaped = padded.reshape(nbh, s, nbw, s)\n","            block_sum = reshaped.sum(axis=(1, 3))\n","            N = np.count_nonzero(block_sum)\n","        except Exception:\n","            # 回退到逐块遍历\n","            N = 0\n","            for i in range(nbh):\n","                for j in range(nbw):\n","                    if padded[i*s:(i+1)*s, j*s:(j+1)*s].any():\n","                        N += 1\n","        counts.append(float(N))\n","\n","    counts = np.array(counts)\n","    # 过滤无效计数\n","    valid = counts > 0\n","    if np.sum(valid) < 2:\n","        return (0.0, sizes, counts.tolist()) if return_counts else 0.0\n","\n","    sizes_valid = np.array(sizes)[valid]\n","    counts_valid = counts[valid]\n","\n","    # 线性拟合计算分形维数\n","    x = np.log(1.0 / sizes_valid.astype(float))\n","    y = np.log(counts_valid)\n","    finite = np.isfinite(x) & np.isfinite(y)\n","    if np.sum(finite) < 2:\n","        return (0.0, sizes_valid.tolist(), counts_valid.tolist()) if return_counts else 0.0\n","\n","    # Fix: Separate the assignments\n","    x = x[finite]\n","    y = y[finite]\n","    coeffs = np.polyfit(x, y, 1)\n","    fd = float(coeffs[0]) if np.isfinite(coeffs[0]) else 0.0\n","\n","    return (fd, sizes_valid.tolist(), counts_valid.tolist()) if return_counts else fd"],"metadata":{"id":"Rgn6BZaVmx0z"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# =============================================================================\n","# 自定义函数：核方法和统计距离\n","# =============================================================================\n","def gaussian_kernel(X, Y=None, sigma=None):\n","    \"\"\"\n","    计算高斯核矩阵。\n","\n","    参数:\n","        X: 数据矩阵 (n, d)\n","        Y: 数据矩阵 (m, d), 默认与X相同\n","        sigma: 核宽度参数 (float, optional)\n","\n","    返回:\n","        核矩阵 (n, m)\n","    \"\"\"\n","    X = np.atleast_2d(X)\n","    Y = np.atleast_2d(Y) if Y is not None else X\n","\n","    XX = np.sum(X**2, axis=1)[:, None]\n","    YY = np.sum(Y**2, axis=1)[None, :]\n","    D2 = XX + YY - 2 * (X @ Y.T)\n","\n","    if sigma is None:\n","        dists = D2.flatten()\n","        dists = dists[np.isfinite(dists) & (dists > 0)]\n","        sigma = np.sqrt(0.5 * np.median(dists)) if dists.size > 0 else 1.0\n","\n","    K = np.exp(-D2 / (2.0 * (sigma ** 2)))\n","    return K\n","\n","def compute_mmd(x, y, sigma=None):\n","    \"\"\"\n","    计算最大均值差异 (MMD²)。\n","\n","    参数:\n","        x, y: 数据数组\n","        sigma: 核宽度 (float, optional)\n","\n","    返回:\n","        MMD²值 (float)\n","    \"\"\"\n","    x, y = np.atleast_2d(x), np.atleast_2d(y)\n","    nx, ny = x.shape[0], y.shape[0]\n","    if nx < 1 or ny < 1:\n","        return 0.0\n","\n","    Kxx = gaussian_kernel(x, x, sigma)\n","    Kyy = gaussian_kernel(y, y, sigma)\n","    Kxy = gaussian_kernel(x, y, sigma)\n","\n","    sum_kxx = (np.sum(Kxx) - np.trace(Kxx)) / (nx * (nx - 1)) if nx > 1 else 0.0\n","    sum_kyy = (np.sum(Kyy) - np.trace(Kyy)) / (ny * (ny - 1)) if ny > 1 else 0.0\n","    sum_kxy = np.sum(Kxy) / (nx * ny)\n","\n","    return float(sum_kxx + sum_kyy - 2.0 * sum_kxy)\n","\n","def compute_hsic(X, Y, sigma_x=None, sigma_y=None, normalize=False):\n","    \"\"\"\n","    计算希尔伯特-施密特独立性准则 (HSIC)。\n","\n","    参数:\n","        X, Y: 数据矩阵\n","        sigma_x, sigma_y: 核宽度 (float, optional)\n","        normalize: 是否归一化 (bool)\n","\n","    返回:\n","        HSIC值 (float)\n","    \"\"\"\n","    X, Y = np.atleast_2d(X), np.atleast_2d(Y)\n","    n = X.shape[0]\n","    if n != Y.shape[0] or n < 2:\n","        return 0.0\n","\n","    K = gaussian_kernel(X, X, sigma_x)\n","    L = gaussian_kernel(Y, Y, sigma_y)\n","    H = np.eye(n) - np.ones((n, n)) / float(n)\n","    Kc, Lc = H @ K @ H, H @ L @ H\n","\n","    hsic = np.trace(Kc @ Lc) / (n ** 2)\n","    if normalize:\n","        denom = np.sqrt(np.trace(Kc @ Kc) * np.trace(Lc @ Lc))\n","        hsic = hsic / denom if denom > 0 else 0.0\n","\n","    return float(hsic)"],"metadata":{"id":"TT-4E_7XNFg7"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# =============================================================================\n","# 干质量计算函数\n","# =============================================================================\n","def color_to_phase(color_img):\n","    \"\"\"\n","    将RGB相位图转换为相位值 (rad)\n","    映射规则:\n","        - HSV色相通道: 蓝色(240°)→0rad, 红色(0°)→2π rad\n","        - 线性映射: phase = (hue/240) * 2π\n","    \"\"\"\n","    hsv = cv2.cvtColor(color_img, cv2.COLOR_RGB2HSV)\n","    hue = hsv[:,:,0].astype(float)\n","    phase = (hue/240) * 2 * np.pi  # 240°对应蓝色\n","    return phase\n","\n","def calculate_dry_mass(phase_value, area_um2):\n","    \"\"\"\n","    计算单个实例的干质量 (pg)。\n","\n","    参数:\n","        phase_value: 实例的平均相位值 (rad)\n","        area_um2: 实例的面积 (µm²)\n","\n","    返回:\n","        干质量 (pg)\n","    \"\"\"\n","    # 使用全局常量 WAVELENGTH 和 ALPHA\n","    alpha_si = ALPHA * 1e-3  # 将 mL/g 转换为 L/g\n","\n","    # 计算质量 (单位: pg)\n","    mass_pg = (WAVELENGTH / (2 * np.pi * alpha_si)) * phase_value * area_um2*100\n","\n","\n","    return float(mass_pg)"],"metadata":{"id":"A-91KoZcNMVO"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["\n","# =============================================================================\n","# 特征计算函数\n","# =============================================================================\n","def calculate_intensity_features(mask, roi_img):\n","    \"\"\"\n","    计算强度特征。\n","\n","    参数:\n","        mask: 二值掩膜\n","        roi_img: ROI灰度图像\n","\n","    返回:\n","        强度特征字典\n","    \"\"\"\n","    if mask.sum() == 0:\n","        return {\n","            'intensity_mean': 0.0,\n","            'intensity_std': 0.0,\n","            'intensity_max': 0.0,\n","            'intensity_min': 0.0\n","        }\n","\n","    roi_pixels = roi_img[mask > 0]\n","    if len(roi_pixels) == 0:\n","        return {\n","            'intensity_mean': 0.0,\n","            'intensity_std': 0.0,\n","            'intensity_max': 0.0,\n","            'intensity_min': 0.0\n","        }\n","\n","    return {\n","        'intensity_mean': float(np.mean(roi_pixels)),\n","        'intensity_std': float(np.std(roi_pixels)),\n","        'intensity_max': float(np.max(roi_pixels)),\n","        'intensity_min': float(np.min(roi_pixels))\n","    }\n","\n","def calculate_instance_features(p, labeled_masks, fractal_func, gray_img, phase_img_rad):\n","    \"\"\"\n","    计算单个实例的形态学、纹理和相位特征。\n","\n","    参数:\n","        p: RegionProperties对象\n","        labeled_masks: 标记掩膜\n","        fractal_func: 分形维数计算函数\n","        gray_img: 灰度图像\n","        phase_img_rad: 相位值图像 (rad)\n","\n","    返回:\n","        特征字典\n","    \"\"\"\n","    # 基本形态学特征\n","    area_px = p.area\n","    # --- 筛选机制：面积小于 6.4 um^2 (1000个像素点）判定为噪声 ---\n","    if area_px < 1000:\n","        return None\n","    perimeter = p.perimeter if p.perimeter > 0 else 1.0\n","    circularity = (4.0 * np.pi * area_px) / (perimeter ** 2)\n","    #if circularity < 0.3:  #考虑到融合到一半的血小板呈现为聚集体附近的狭长状\n","    #    return None\n","    maj = p.major_axis_length if p.major_axis_length > 0 else 1.0\n","    mino = p.minor_axis_length if p.minor_axis_length > 0 else 1.0\n","    aspect_ratio = maj / mino\n","    #if aspect_ratio > 3:\n","    #    return None\n","    solidity = p.solidity if hasattr(p, 'solidity') else (p.area / p.convex_area if p.convex_area > 0 else 1.0)\n","    eccentricity = p.eccentricity\n","    bbox = p.bbox\n","    centroid = p.centroid\n","\n","    # 分形维数\n","    minr, minc, maxr, maxc = bbox\n","    inst_mask = (labeled_masks[minr:maxr, minc:maxc] == p.label).astype(np.uint8)\n","    MIN_PIXELS_FOR_FD = 20\n","    fractal_dim = fractal_func(inst_mask) if inst_mask.sum() >= MIN_PIXELS_FOR_FD else 0.0\n","\n","    # 纹理和强度特征\n","    roi_gray = gray_img[minr:maxr, minc:maxc]\n","    intensity_features = calculate_intensity_features(inst_mask, roi_gray)\n","\n","    # 相位特征\n","    if inst_mask.sum() > 0:\n","        roi_phase = phase_img_rad[minr:maxr, minc:maxc]\n","        mean_phase_rad = float(np.mean(roi_phase[inst_mask > 0]))\n","    else:\n","        mean_phase_rad = 0.0\n","\n","    # 合并特征\n","    features = {\n","        \"label\": int(p.label),\n","        \"area_px\": int(area_px),\n","        \"perimeter_px\": float(perimeter),\n","        \"circularity\": float(circularity),\n","        \"aspect_ratio\": float(aspect_ratio),\n","        \"solidity\": float(solidity),\n","        \"eccentricity\": float(eccentricity),\n","        \"bbox_minr\": int(bbox[0]),\n","        \"bbox_minc\": int(bbox[1]),\n","        \"bbox_maxr\": int(bbox[2]),\n","        \"bbox_maxc\": int(bbox[3]),\n","        \"centroid_r\": float(centroid[0]),\n","        \"centroid_c\": float(centroid[1]),\n","        \"fractal_dim\": float(fractal_dim),\n","        \"mean_phase_rad\": mean_phase_rad # 添加平均相位值\n","    }\n","    features.update(intensity_features)\n","    return features"],"metadata":{"id":"Lhrx6PI4NTwG"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import cv2\n","from scipy.spatial.distance import cdist\n","from scipy.sparse import csr_matrix\n","from scipy.sparse.csgraph import connected_components\n","\n","def classify_instances_with_graph(records, area_threshold_px, labeled_array):\n","    \"\"\"\n","    优化版图算法：使用 cv2.findContours 提取轮廓点集进行精确距离判定\n","    \"\"\"\n","    if not records:\n","        return records\n","\n","    # --- 阶段 1: 形态学初步判定 ---\n","    for r in records:\n","        is_morph_aggregate = (\n","            r[\"area_px\"] > area_threshold_px or\n","            r[\"solidity\"] < SOLIDITY_THRESHOLD or\n","            r[\"aspect_ratio\"] > ASPECT_RATIO_THRESHOLD\n","        )\n","        r[\"is_aggregate\"] = is_morph_aggregate\n","\n","    # --- 阶段 2: 构建增强型邻接矩阵 ---\n","    centroids = np.array([[r[\"centroid_r\"], r[\"centroid_c\"]] for r in records])\n","    n_nodes = len(centroids)\n","    adj_matrix = np.eye(n_nodes, dtype=int)\n","\n","    # 预计算质心距离矩阵（粗筛）\n","    diff = centroids[:, np.newaxis, :] - centroids[np.newaxis, :, :]\n","    dist_matrix = np.sqrt(np.sum(diff**2, axis=-1))\n","\n","    # 轮廓缓存：存储全局坐标系下的轮廓点\n","    contour_cache = {}\n","\n","    for i in range(n_nodes):\n","        for j in range(i + 1, n_nodes):\n","            # A. 粗筛：质心距离过远\n","            if dist_matrix[i, j] > 1.8 * NEIGHBOR_DISTANCE_THRESHOLD:\n","                continue\n","\n","            # B. 中筛：质心距离极近（重叠）\n","            if dist_matrix[i, j] < 0.7 * NEIGHBOR_DISTANCE_THRESHOLD:\n","                adj_matrix[i, j] = adj_matrix[j, i] = 1\n","                continue\n","\n","            # C. 精筛：基于轮廓点的最短距离计算\n","            for idx in [i, j]:\n","                if idx not in contour_cache:\n","                    r_obj = records[idx]\n","                    m_r, m_c = r_obj[\"bbox_minr\"], r_obj[\"bbox_minc\"]\n","                    # 提取局部掩膜\n","                    local_mask = (labeled_array[m_r:r_obj[\"bbox_maxr\"], m_c:r_obj[\"bbox_maxc\"]] == r_obj[\"label\"]).astype(np.uint8)\n","\n","                    # 使用 cv2 提取轮廓\n","                    contours, _ = cv2.findContours(local_mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n","\n","                    if contours:\n","                        # 合并所有可能的轮廓点（通常只有一个），并转换为 (N, 2) 数组\n","                        pts = np.vstack(contours).squeeze(axis=1)\n","                        # 转换回全局坐标 [row, col] -> [y, x]\n","                        # 注意：cv2 坐标是 (x, y)，这里转为 (row, col) 需要交换并加偏移\n","                        global_pts = pts[:, [1, 0]] + [m_r, m_c]\n","                        contour_cache[idx] = global_pts.astype(np.float32)\n","                    else:\n","                        # 兜底：如果没找到轮廓，用质心代替\n","                        contour_cache[idx] = np.array([[r_obj[\"centroid_r\"], r_obj[\"centroid_c\"]]], dtype=np.float32)\n","\n","            # 计算两组轮廓点之间的最短距离\n","            d_min = np.min(cdist(contour_cache[i], contour_cache[j]))\n","\n","            if d_min < 5:  # 边缘距离阈值\n","                adj_matrix[i, j] = adj_matrix[j, i] = 1\n","\n","    # --- 阶段 3: 连通分量 (保持不变) ---\n","    n_components, labels = connected_components(csgraph=csr_matrix(adj_matrix), directed=False)\n","    unique_labels, counts = np.unique(labels, return_counts=True)\n","    cluster_size_map = dict(zip(unique_labels, counts))\n","\n","    for i, r in enumerate(records):\n","        cluster_id = labels[i]\n","        r[\"cluster_id\"] = int(cluster_id)\n","        r[\"cluster_size\"] = int(cluster_size_map[cluster_id])\n","        if r[\"cluster_size\"] > 1:\n","            r[\"is_aggregate\"] = True\n","\n","    return records"],"metadata":{"id":"mr_aHcvbNbsT"},"execution_count":null,"outputs":[]},{"cell_type":"code","execution_count":null,"metadata":{"collapsed":true,"id":"CYj-NKpeRx8S"},"outputs":[],"source":["def analyze_masks_and_save(img, masks, brightfield_img, filename_base, output_dir):\n","    \"\"\"\n","    完整的图像分析函数：\n","    1. 提取单细胞特征并进行图算法分类 (A-B-C 逻辑)。\n","    2. 对聚集体进行物理合并，通过合并成员 Bbox 解决框不全的问题。\n","    3. 执行分类裁切 (Crops)、双掩膜保存、YOLO 标注导出。\n","    \"\"\"\n","    # --- 1. 基础准备 ---\n","    gray_img = cv2.cvtColor(brightfield_img, cv2.COLOR_RGB2GRAY)\n","    phase_img_rad = color_to_phase(img)\n","    labeled = masks.astype(np.int32)\n","    pixel_area_um2 = PIXEL_TO_MICRON ** 2\n","\n","    # 提取所有初始检测到的实例\n","    props = measure.regionprops(labeled)\n","    if len(props) == 0:\n","        return 0, {\"filename\": filename_base, \"n_platelets\": 0}\n","\n","    # 计算基础特征并应用图算法分类\n","    records_initial = []\n","    for p in props:\n","        feat = calculate_instance_features(p, labeled, fractal_dimension_boxcount, gray_img, phase_img_rad)\n","        if feat is not None:\n","          feat[\"image_id\"] = filename_base\n","          records_initial.append(feat)\n","\n","    # 注入 is_aggregate, cluster_id, cluster_size 等\n","    records_initial = classify_instances_with_graph(records_initial, area_threshold_px, labeled)\n","\n","    # --- 2. 最终结果容器 ---\n","    final_records = []\n","